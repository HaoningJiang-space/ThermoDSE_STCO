# Minimal HotSpot grid configuration for ThermoDSE-generated 3D floorplans.

# chip specs
-t_chip              0.00015
-material_chip       silicon

# heat sink / spreader specs. run.sh overrides side length per design.
-material_sink       copper
-c_convec            140.4
-r_convec            0.1
-s_sink              0.06
-t_sink              0.0069
-material_spreader   copper
-s_spreader          0.05
-t_spreader          0.001

# interface material specs
-t_interface         2.0e-05
-k_interface         4.0
-p_interface         4.0e6

# secondary path disabled for this ThermoDSE flow
-model_secondary     0

# ambient and simulation settings
-ambient             318.15
-init_file           (null)
-init_temp           318.15
-steady_file         (null)
-sampling_intvl      0.01
-base_proc_freq      3e+09
-dtm_used            0
-model_type          block
-leakage_used        0
-leakage_mode        0
-package_model_used  0
-package_config_file package.config

# grid model settings
-grid_rows           64
-grid_cols           64
-grid_layer_file     (null)
-grid_steady_file    (null)
-grid_map_mode       avg

# microfluidic cooling disabled
-use_microfluidic_cooling 0
